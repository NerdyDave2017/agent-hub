# Full DB URL (postgresql+asyncpg or postgresql); omit to use DATABASE_* instead
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/postgres

# if DATABASE_URL omitted:
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=postgres

# APP_NAME=agent-hub
# API_V1_PREFIX=/api/v1

AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1

# LocalStack / custom endpoint; unset for real AWS
AWS_ENDPOINT_URL=http://127.0.0.1:4566

# Dummy for LocalStack; omit in prod when using IAM
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Main jobs queue; omit to skip SendMessage
SQS_QUEUE_URL=

# Optional DLQ URL
SQS_DLQ_URL=

# Langfuse public host for dashboard trace links (no secrets)
# LANGFUSE_HOST=https://cloud.langfuse.com
# Optional: worker ``metrics_rollup`` merges Langfuse Public Metrics API totals when set
# (``userId`` filter = hub tenant UUID — align with incident-triage Langfuse user metadata).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# Worker: enqueue metrics_rollup for every active agent each interval (seconds); 0 disables
# METRICS_ROLLUP_SCHEDULER_SECONDS=3600

# Worker: enqueue gmail_watch_renewal on this interval (seconds); 0 disables (legacy: GMAIL_RENEWAL_SCHEDULER_SECONDS)
# GOOGLE_RENEWAL_SCHEDULER_SECONDS=86400

# Bearer for agent → hub /internal/* (must match agent HUB_SERVICE_TOKEN)
# INTERNAL_SERVICE_TOKEN=

# Dashboard JWT (HS256) — required for /api/v1/auth/login, /api/v1/auth/signup, and
# /api/v1/tenants/{id}/dashboard/*
# JWT_SECRET_KEY=change-me-to-a-long-random-string
# JWT_EXPIRE_MINUTES=60
# JWT_ISSUER=agent-hub

# Google OAuth web client (Gmail hub integration + Sign-In with Google ID token ``aud``).
# Set GOOGLE_OAUTH_CLIENT_ID (and secret). Legacy env name GOOGLE_SIGNIN_CLIENT_ID is also accepted.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Public URL of the hub (OAuth redirect_uri is derived from this + API_V1_PREFIX unless overridden).
# Must match what you paste in Slack / Google cloud consoles (http vs https, host, port).
# http://127.0.0.1:8000 and http://localhost:8000 are different — pick one and use it everywhere.
# HUB_PUBLIC_URL=http://127.0.0.1:8000

# Gmail OAuth: Google Cloud Console → Credentials → OAuth client → Authorized redirect URIs must include
# exactly: {HUB_PUBLIC_URL}{API_V1_PREFIX}/integrations/gmail/oauth/callback
# e.g. http://127.0.0.1:8000/api/v1/integrations/gmail/oauth/callback
# Optional: full redirect URI if it cannot match HUB_PUBLIC_URL (must still match Google client config).
# GMAIL_OAUTH_REDIRECT_URI=

# Slack OAuth (Install to Workspace). In Slack app: OAuth & Permissions → Redirect URLs must include
# exactly: {HUB_PUBLIC_URL}{API_V1_PREFIX}/integrations/slack/oauth/callback
# e.g. http://127.0.0.1:8000/api/v1/integrations/slack/oauth/callback
# SLACK_OAUTH_CLIENT_ID=
# SLACK_OAUTH_CLIENT_SECRET=
# Optional: full redirect URI if it cannot match HUB_PUBLIC_URL (must still match Slack app config).
# SLACK_OAUTH_REDIRECT_URI=
# Optional: UI origin for postMessage after popup OAuth (defaults to origin of HUB_PUBLIC_URL).
# SLACK_OAUTH_PARENT_ORIGIN=http://localhost:3000
