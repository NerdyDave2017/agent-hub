# Full DB URL (postgresql+asyncpg or postgresql); omit to use DATABASE_* instead
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/postgres

# if DATABASE_URL omitted:
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=postgres

# APP_NAME=agent-hub
# API_V1_PREFIX=/api/v1

AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1

# LocalStack / custom endpoint; unset for real AWS
AWS_ENDPOINT_URL=http://127.0.0.1:4566

# Dummy for LocalStack; omit in prod when using IAM
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Main jobs queue; omit to skip SendMessage
SQS_QUEUE_URL=

# Optional DLQ URL
SQS_DLQ_URL=

# Langfuse public host for dashboard trace links (no secrets)
# LANGFUSE_HOST=https://cloud.langfuse.com
# Optional: worker ``metrics_rollup`` merges Langfuse Public Metrics API totals when set
# (``userId`` filter = hub tenant UUID — align with incident-triage Langfuse user metadata).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# Worker: enqueue metrics_rollup for every active agent each interval (seconds); 0 disables
# METRICS_ROLLUP_SCHEDULER_SECONDS=3600

# Worker: enqueue gmail_watch_renewal on this interval (seconds); 0 disables (legacy: GMAIL_RENEWAL_SCHEDULER_SECONDS)
# GOOGLE_RENEWAL_SCHEDULER_SECONDS=86400

# Bearer for agent → hub /internal/* (must match agent HUB_SERVICE_TOKEN)
# INTERNAL_SERVICE_TOKEN=

# Dashboard JWT (HS256) — required for /api/v1/auth/login, /api/v1/auth/signup, and
# /api/v1/tenants/{id}/dashboard/*
# JWT_SECRET_KEY=change-me-to-a-long-random-string
# JWT_EXPIRE_MINUTES=60
# JWT_ISSUER=agent-hub

# Google Sign-In (user auth) — frontend "Sign in with Google" button
# This is the OAuth client ID configured in Google Cloud Console for web sign-in.
# NOT the same as GOOGLE_OAUTH_CLIENT_ID (Gmail API / hub mail integration OAuth).
# GOOGLE_SIGNIN_CLIENT_ID=
