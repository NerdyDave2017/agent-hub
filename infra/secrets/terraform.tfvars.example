environment = "staging"
# Hub JWT signing key is generated by Terraform (random_password) like INTERNAL_SERVICE_TOKEN — no tfvars entry.
# Optional after hub/worker exist — re-apply to extend KMS policy:
# hub_role_arn    = "arn:aws:iam::123456789012:role/agent-hub-staging-hub-instance"
# worker_role_arn = "arn:aws:iam::123456789012:role/agent-hub-staging-worker-task"
