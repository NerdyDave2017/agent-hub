environment = "staging"
aws_account_id = "123456789012"
hub_image_uri  = "123456789012.dkr.ecr.us-east-1.amazonaws.com/agent-hub/hub:latest"
frontend_url   = "https://app.example.com"
google_pubsub_topic = "projects/your-gcp/topics/google-push"
gcp_project_id     = "your-gcp"
google_oauth_client_id     = "your-google-oauth-client-id.apps.googleusercontent.com"
google_oauth_client_secret = "your-google-oauth-client-secret"
google_webhook_secret      = "replace-me-with-random-secret"
slack_oauth_client_id_arn     = "arn:aws:secretsmanager:us-east-1:123456789012:secret:agent-hub/staging/slack/oauth-client-id"
slack_oauth_client_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:agent-hub/staging/slack/oauth-client-secret"
# worker_role_arn = ""  # set after worker apply, then terraform apply again in hub/
