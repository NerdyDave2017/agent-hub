environment = "staging"
aws_account_id = "123456789012"
hub_image_uri  = "123456789012.dkr.ecr.us-east-1.amazonaws.com/agent-hub/hub:latest"
frontend_url   = "https://app.example.com"
gmail_pubsub_topic = "projects/your-gcp/topics/gmail-push"
gcp_project_id     = "your-gcp"
gmail_oauth_client_id_arn     = "arn:aws:secretsmanager:us-east-1:123456789012:secret:agent-hub/staging/gmail/oauth-client-id"
gmail_oauth_client_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:agent-hub/staging/gmail/oauth-client-secret"
gmail_webhook_secret_arn      = "arn:aws:secretsmanager:us-east-1:123456789012:secret:agent-hub/staging/gmail/webhook-secret"
slack_oauth_client_id_arn     = "arn:aws:secretsmanager:us-east-1:123456789012:secret:agent-hub/staging/slack/oauth-client-id"
slack_oauth_client_secret_arn = "arn:aws:secretsmanager:us-east-1:123456789012:secret:agent-hub/staging/slack/oauth-client-secret"
